// FindMyTutor — Prisma Schema
// Two-sided marketplace connecting college student tutors with parents

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum Role {
  ADMIN
  TUTOR
  PARENT
}

enum TeachingMode {
  ONLINE
  OFFLINE
  BOTH
}

enum LeadStatus {
  PENDING
  ACCEPTED
  DECLINED
}

// ─── NextAuth Required Models ────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?   // For email/password auth (hashed)
  role          Role      @default(PARENT)

  accounts     Account[]
  sessions     Session[]
  tutorProfile TutorProfile?
  leads        Lead[]    // Leads created by this parent

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Application Models ──────────────────────────────────────────────────────

model TutorProfile {
  id                String       @id @default(cuid())
  userId            String       @unique
  phone             String
  collegeName       String
  degree            String
  yearOfStudy       Int?
  bio               String       @db.Text
  teachingMode      TeachingMode @default(BOTH)
  idCardUrl         String?      // Cloudinary URL for college ID card
  profilePictureUrl String?      // Cloudinary URL for profile picture
  isVerified        Boolean      @default(false)

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  tutorSubjects TutorSubject[]
  leads         Lead[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Subject {
  id   String @id @default(cuid())
  name String @unique

  tutorSubjects TutorSubject[]

  createdAt DateTime @default(now())
}

model TutorSubject {
  id             String @id @default(cuid())
  tutorProfileId String
  subjectId      String

  tutorProfile TutorProfile @relation(fields: [tutorProfileId], references: [id], onDelete: Cascade)
  subject      Subject      @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@unique([tutorProfileId, subjectId])
}

model Lead {
  id             String     @id @default(cuid())
  parentId       String
  tutorProfileId String
  message        String?    @db.Text
  status         LeadStatus @default(PENDING)

  parent       User         @relation(fields: [parentId], references: [id], onDelete: Cascade)
  tutorProfile TutorProfile @relation(fields: [tutorProfileId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([parentId, tutorProfileId]) // One lead per parent-tutor pair
}
